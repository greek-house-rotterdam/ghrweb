---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";
import { getCollection } from "astro:content";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const allResources = await getCollection("resources");
const resources = allResources
  .filter((r) => r.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const categories = [...new Set(resources.map((r) => r.data.category))];
---

<Layout title={t(lang, "resources.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "resources.title")}</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl">
        {t(lang, "resources.intro")}
      </p>

      {categories.map((category) => (
        <div class="mt-12">
          <h2 class="text-2xl font-extrabold text-black capitalize border-b-2 border-black pb-2">
            {category}
          </h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {resources
              .filter((r) => r.data.category === category)
              .map((resource) => (
                <div class="border-2 border-black bg-white p-6 shadow-[4px_4px_0_0_#000]">
                  <h3 class="text-lg font-extrabold">{resource.data.title}</h3>
                  <p class="mt-2 text-sm text-gray-700">{resource.data.description}</p>
                </div>
              ))}
          </div>
        </div>
      ))}

      {resources.length === 0 && (
        <div class="mt-10 border-2 border-black border-dashed bg-gray-50 p-10 text-center">
          <p class="text-gray-500 font-bold">{t(lang, "resources.none")}</p>
        </div>
      )}
    </div>
  </section>
</Layout>
