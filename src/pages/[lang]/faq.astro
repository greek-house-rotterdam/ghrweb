---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";
import { getCollection } from "astro:content";
import { Accordion, AccordionItem, AccordionTrigger, AccordionContent } from "@/components/starwind/accordion";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const allFaqs = await getCollection("faq");
const faqs = allFaqs
  .filter((f) => f.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={t(lang, "faq.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "faq.title")}</h1>

      {faqs.length > 0 && (
        <Accordion type="single" class="mt-10 space-y-3">
          {faqs.map((faq) => (
            <AccordionItem
              value={faq.id}
              class="border-2 border-black bg-white shadow-[4px_4px_0_0_#000] !border-b-2"
            >
              <AccordionTrigger class="px-5 py-4 font-bold text-black hover:bg-accent-gold-light focus:bg-accent-gold-light transition-colors">
                {faq.data.question}
              </AccordionTrigger>
              <AccordionContent class="border-t-2 border-black">
                <div class="px-5 py-4">
                  <p class="text-gray-700 leading-relaxed">{faq.data.answer}</p>
                </div>
              </AccordionContent>
            </AccordionItem>
          ))}
        </Accordion>
      )}

      {faqs.length === 0 && (
        <div class="mt-10 border-2 border-black border-dashed bg-gray-50 p-10 text-center">
          <p class="text-gray-500 font-bold">No FAQs yet.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
