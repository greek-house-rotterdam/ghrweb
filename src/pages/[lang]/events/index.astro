---
import Layout from "../../../layouts/Layout.astro";
import { t } from "../../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../../i18n/utils";
import { getCollection } from "astro:content";
import { Button } from "@/components/starwind/button";
import BrutCard from "../../../components/BrutCard.astro";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const allEvents = await getCollection("events");
const events = allEvents
  .filter((event) => event.data.lang === lang)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const categories = ["all", "workshop", "social", "cultural", "class", "meetup", "other"] as const;
---

<Layout title={t(lang, "nav.events")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "nav.events")}</h1>

      {/* Category filter */}
      <div class="mt-6 flex flex-wrap gap-2" id="category-filter">
        {categories.map((cat) => (
          <Button
            variant={cat === "all" ? "default" : "outline"}
            size="sm"
            data-category={cat}
            class:list={[
              "border-2 border-black font-bold uppercase",
              cat === "all"
                ? "bg-black text-white"
                : "bg-white text-black hover:bg-accent-gold",
            ]}
          >
            {cat === "all" ? t(lang, "common.all") : cat}
          </Button>
        ))}
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="events-grid">
        {events.map((event) => (
          <BrutCard tag="a" href={`/${lang}/events/${event.id.split("/").pop()}`} interactive class="event-card block bg-white overflow-hidden" data-category={event.data.category}>
            {event.data.image && (
              <img
                src={event.data.image}
                alt={event.data.title}
                class="w-full h-40 object-cover border-b-2 border-black"
              />
            )}
            <div class="p-6">
              <div class="flex flex-wrap gap-2">
                <span class="inline-block border border-black bg-primary-light px-2 py-0.5 text-xs font-bold uppercase">
                  {event.data.date.toLocaleDateString(lang)}
                </span>
                {event.data.location && (
                  <span class="inline-block border border-black bg-green-100 px-2 py-0.5 text-xs font-bold">
                    📍 {event.data.location}
                  </span>
                )}
                {event.data.category && event.data.category !== "other" && (
                  <span class="inline-block border border-black bg-accent-gold-light px-2 py-0.5 text-xs font-bold uppercase">
                    {event.data.category}
                  </span>
                )}
              </div>
              <h3 class="mt-3 text-lg font-extrabold leading-snug">{event.data.title}</h3>
              <p class="mt-2 text-sm text-gray-600 line-clamp-2">{event.data.description}</p>
              {(event.data.price || event.data.registrationRequired) && (
                <div class="mt-3 flex flex-wrap gap-2 text-xs font-bold">
                  {event.data.price && (
                    <span class="inline-block border border-black bg-white px-2 py-0.5">
                      {event.data.price}
                    </span>
                  )}
                  {event.data.registrationRequired && (
                    <span class="inline-block border border-black bg-red-100 px-2 py-0.5">
                      {t(lang, "events.registration-required")}
                    </span>
                  )}
                </div>
              )}
            </div>
          </BrutCard>
        ))}
      </div>

      {events.length === 0 && (
        <div class="mt-10 border-2 border-black border-dashed bg-gray-50 p-10 text-center">
          <p class="text-gray-500 font-bold">{t(lang, "events.none")}</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  const filter = document.getElementById("category-filter");
  const cards = document.querySelectorAll<HTMLElement>(".event-card");

  filter?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest("button");
    if (!btn) return;

    const cat = btn.dataset.category;

    // Update active button style
    filter.querySelectorAll("button").forEach((b) => {
      b.classList.remove("bg-black", "text-white");
      b.classList.add("bg-white", "text-black");
    });
    btn.classList.remove("bg-white", "text-black");
    btn.classList.add("bg-black", "text-white");

    // Filter cards
    cards.forEach((card) => {
      card.style.display =
        cat === "all" || card.dataset.category === cat ? "" : "none";
    });
  });
</script>
