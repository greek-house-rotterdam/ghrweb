---
import Layout from "../../../layouts/Layout.astro";
import { t } from "../../../i18n/ui";
import type { Lang } from "../../../i18n/utils";
import { getCollection, render } from "astro:content";
import BrutButton from "../../../components/BrutButton.astro";

export async function getStaticPaths() {
  const allEvents = await getCollection("events");
  return allEvents.map((event) => {
    const lang = event.id.split("/")[0];
    const slug = event.id.split("/").slice(1).join("/");
    return { params: { lang, slug }, props: { event } };
  });
}

const { event } = Astro.props;
const { lang } = Astro.params as { lang: Lang };
const { Content } = await render(event);
---

<Layout title={event.data.title} description={event.data.description} lang={lang}>
  <article class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <BrutButton href={`/${lang}/events`} size="sm" class="bg-white text-black hover:bg-accent-gold">
        ← {t(lang, "common.back")}
      </BrutButton>

      <div class="mt-8">
        <div class="flex flex-wrap gap-2">
          <span class="inline-block border border-black bg-primary-light px-2 py-0.5 text-xs font-bold uppercase">
            {event.data.date.toLocaleDateString(lang)}
          </span>
          {event.data.location && (
            <span class="inline-block border border-black bg-green-100 px-2 py-0.5 text-xs font-bold">
              📍 {event.data.location}
            </span>
          )}
          {event.data.category && event.data.category !== "other" && (
            <span class="inline-block border border-black bg-accent-gold-light px-2 py-0.5 text-xs font-bold uppercase">
              {event.data.category}
            </span>
          )}
          {event.data.translation_locked && (
            <span class="inline-block border border-black bg-blue-100 px-2 py-0.5 text-xs font-bold uppercase">
              {t(lang, "common.manually-edited")}
            </span>
          )}
        </div>
        <h1 class="mt-3 text-3xl font-extrabold text-black sm:text-4xl">{event.data.title}</h1>
        <p class="mt-3 text-lg text-gray-600">{event.data.description}</p>

        {(event.data.price || event.data.registrationRequired) && (
          <div class="mt-4 flex flex-wrap gap-2 text-sm font-bold">
            {event.data.price && (
              <span class="inline-block border-2 border-black bg-white px-3 py-1">
                {event.data.price}
              </span>
            )}
            {event.data.registrationRequired && (
              <span class="inline-block border-2 border-black bg-red-100 px-3 py-1">
                {t(lang, "events.registration-required")}
              </span>
            )}
          </div>
        )}
      </div>

      {event.data.image && (
        <img
          src={event.data.image}
          alt={event.data.title}
          class="mt-8 w-full border-2 border-black object-cover"
        />
      )}

      <div class="mt-10 border-t-2 border-black pt-8 prose prose-lg max-w-none prose-headings:font-extrabold prose-a:text-primary prose-a:underline prose-a:decoration-2">
        <Content />
      </div>
    </div>
  </article>
</Layout>
