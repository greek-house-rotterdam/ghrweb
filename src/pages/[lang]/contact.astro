---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";
import BrutCard from "../../components/BrutCard.astro";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };
---

<Layout title={t(lang, "contact.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "contact.title")}</h1>

      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        {/* Contact form */}
        <BrutCard class="bg-white p-6">
          <h2 class="text-xl font-extrabold">{t(lang, "contact.form.title")}</h2>
          <div class="mt-4">
            {/* TODO: Replace with actual Google Form embed URL */}
            <iframe
              src="https://docs.google.com/forms/d/e/FORM_ID/viewform?embedded=true"
              width="100%"
              height="500"
              class="border-2 border-black"
              title="Contact Form"
            >
              Loading…
            </iframe>
          </div>
        </BrutCard>

        {/* Contact info + map */}
        <div class="space-y-6">
          <BrutCard class="bg-accent-gold-lighter p-6">
            <h2 class="text-xl font-extrabold">{t(lang, "contact.info.title")}</h2>
            <div class="mt-4 space-y-3">
              <div class="flex items-start gap-3">
                <span class="text-lg">📍</span>
                <div>
                  <p class="font-bold text-sm">Greek House in Rotterdam</p>
                  <p class="text-sm text-gray-600">Address TBD, Rotterdam, NL</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-lg">📞</span>
                <p class="text-sm text-gray-600">+31 (0) XX XXX XXXX</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-lg">✉️</span>
                <a href="mailto:het.griekse.huis@gmail.com" class="text-sm text-gray-600 hover:text-black hover:underline">het.griekse.huis@gmail.com</a>
              </div>
            </div>
          </BrutCard>

          <BrutCard class="bg-white p-6">
            <h2 class="text-xl font-extrabold">{t(lang, "contact.map.title")}</h2>
            <div class="mt-4 aspect-video border-2 border-black overflow-hidden">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2461.0!2d4.47!3d51.92!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTHCsDU1JzEyLjAiTiA0wrAyOCcxMi4wIkU!5e0!3m2!1sen!2snl!4v1"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Google Maps - Greek House in Rotterdam"
              ></iframe>
            </div>
            <a
              href="https://maps.app.goo.gl/LnvqPn8nYoRxkfws7"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-block text-sm font-bold text-primary hover:underline"
            >
              {t(lang, "contact.map.title")} →
            </a>
          </BrutCard>
        </div>
      </div>
    </div>
  </section>
</Layout>
