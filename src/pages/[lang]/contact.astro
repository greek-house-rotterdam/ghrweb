---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";
import BrutCard from "../../components/BrutCard.astro";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const ADDRESS = "Van Vollenhovenstraat 18, 3016 BH Rotterdam";
const MAP_EMBED = `https://www.google.com/maps?q=${encodeURIComponent(ADDRESS)}&output=embed`;
const MAP_LINK = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ADDRESS)}`;
const UNION_EMAIL = "enosi.ellinon.ollandias@gmail.com";
const HOUSE_EMAIL = "het.griekse.huis@gmail.com";
---

<Layout title={t(lang, "contact.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "contact.title")}</h1>

      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        {/* Contact form */}
        <BrutCard class="bg-white p-6">
          <h2 class="text-xl font-extrabold">{t(lang, "contact.form.title")}</h2>
          <div class="mt-4">
            {/* TODO: Replace with actual Google Form embed URL */}
            <iframe
              src="https://docs.google.com/forms/d/e/FORM_ID/viewform?embedded=true"
              width="100%"
              height="500"
              class="border-2 border-black"
              title="Contact Form"
            >
              Loading…
            </iframe>
          </div>
        </BrutCard>

        {/* Contact info + map */}
        <div class="space-y-6">
          <BrutCard class="bg-accent-gold-lighter p-6">
            <h2 class="text-xl font-extrabold">{t(lang, "contact.info.title")}</h2>
            <div class="mt-4 space-y-3">
              <div class="flex items-start gap-3">
                <span class="text-lg">📍</span>
                <div>
                  <p class="font-bold text-sm">{t(lang, "contact.address.label")}</p>
                  <p class="text-sm text-gray-700">{ADDRESS}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-lg">✉️</span>
                <div>
                  <p class="font-bold text-sm">{t(lang, "contact.email.union")}</p>
                  <a href={`mailto:${UNION_EMAIL}`} class="text-sm text-gray-700 hover:text-black hover:underline">
                    {UNION_EMAIL}
                  </a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-lg">✉️</span>
                <div>
                  <p class="font-bold text-sm">{t(lang, "contact.email.house")}</p>
                  <a href={`mailto:${HOUSE_EMAIL}`} class="text-sm text-gray-700 hover:text-black hover:underline">
                    {HOUSE_EMAIL}
                  </a>
                </div>
              </div>
            </div>
          </BrutCard>

          <BrutCard class="bg-white p-6">
            <h2 class="text-xl font-extrabold">{t(lang, "contact.map.title")}</h2>
            <div class="mt-4 aspect-video border-2 border-black overflow-hidden">
              <iframe
                src={MAP_EMBED}
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Google Maps - ${ADDRESS}`}
              ></iframe>
            </div>
            <a
              href={MAP_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-block text-sm font-bold text-primary hover:underline"
            >
              {t(lang, "contact.map.title")} →
            </a>
          </BrutCard>
        </div>
      </div>
    </div>
  </section>
</Layout>
