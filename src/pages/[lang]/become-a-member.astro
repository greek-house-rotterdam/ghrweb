---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const tiers = [
  {
    title: t(lang, "member.friend.title"),
    desc: t(lang, "member.friend.desc"),
    color: "bg-green-100",
    icon: "🤝",
  },
  {
    title: t(lang, "member.member.title"),
    desc: t(lang, "member.member.desc"),
    color: "bg-primary-light",
    icon: "🏛️",
  },
  {
    title: t(lang, "member.candidate.title"),
    desc: t(lang, "member.candidate.desc"),
    color: "bg-accent-gold-light",
    icon: "⭐",
  },
];
---

<Layout title={t(lang, "member.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "member.title")}</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl">
        {t(lang, "member.intro")}
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {tiers.map((tier) => (
          <div class={`border-2 border-black p-6 shadow-[4px_4px_0_0_#000] ${tier.color}`}>
            <span class="text-4xl">{tier.icon}</span>
            <h3 class="mt-4 text-xl font-extrabold">{tier.title}</h3>
            <p class="mt-2 text-sm text-gray-700">{tier.desc}</p>
          </div>
        ))}
      </div>

      {/* CTA */}
      <div class="mt-12 border-4 border-black bg-white p-8 shadow-[6px_6px_0_0_#000] text-center">
        <h2 class="text-2xl font-extrabold">{t(lang, "home.cta.title")}</h2>
        <p class="mt-3 text-gray-600">{t(lang, "home.cta.subtitle")}</p>
        {/* TODO: Replace with actual Google Form link */}
        <a
          href="#"
          class="mt-6 inline-block border-2 border-black bg-primary px-8 py-4 text-lg font-extrabold text-white shadow-[4px_4px_0_0_#000] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all"
        >
          {t(lang, "member.cta")}
        </a>
      </div>
    </div>
  </section>
</Layout>
