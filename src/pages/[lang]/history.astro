---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";
import BrutCard from "../../components/BrutCard.astro";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

// Year-only entries — the year is the visual anchor, descriptions are short.
type Milestone = { year: string; title: string };

const milestones: Record<Lang, Milestone[]> = {
  gr: [
    { year: "1946", title: "Ίδρυση της Ένωσης Ελλήνων Ολλανδίας (ΕΕΟ)" },
    { year: "1954", title: "Θεμέλια της εκκλησίας" },
    { year: "1957", title: "Εγκαίνια της εκκλησίας" },
    { year: "1959", title: "Πρώτο μονοθέσιο Ελληνικό Σχολείο" },
    { year: "1961", title: "Αγορά κτιρίου" },
    { year: "1969", title: "Ελληνικό Σχολείο στην ΕΕΟ" },
    { year: "1992", title: "Φεστιβάλ στην Schouwburgplein" },
    { year: "1994", title: "Επίσκεψη Οικουμενικού Πατριάρχη" },
    { year: "2010", title: "Μεταβίβαση εκκλησίας στη Μητρόπολη" },
    { year: "2017", title: "Έναρξη πολιτιστικής ομάδας Το Ελληνικό Σπίτι" },
    { year: "2022", title: "Μερική ανακαίνιση του Ελληνικού Σπιτιού" },
    { year: "2024", title: "Αποκατάσταση πρόσοψης κτιρίου" },
    { year: "2026", title: "Εορτασμός των 80 χρόνων από την ίδρυση της ΕΕΟ" },
  ],
  nl: [
    { year: "1946", title: "Oprichting van de Vereniging van Grieken in Nederland (EEO)" },
    { year: "1954", title: "Fundament van de kerk" },
    { year: "1957", title: "Inwijding van de kerk" },
    { year: "1959", title: "Eerste eenklassige Griekse school" },
    { year: "1961", title: "Aankoop van het gebouw" },
    { year: "1969", title: "Griekse school bij de EEO" },
    { year: "1992", title: "Festival op het Schouwburgplein" },
    { year: "1994", title: "Bezoek van de Oecumenische Patriarch" },
    { year: "2010", title: "Overdracht van de kerk aan de Metropolis" },
    { year: "2017", title: "Start van de culturele groep Het Griekse Huis" },
    { year: "2022", title: "Gedeeltelijke renovatie van het Griekse Huis" },
    { year: "2024", title: "Restauratie van de gevel van het gebouw" },
    { year: "2026", title: "Viering van 80 jaar EEO" },
  ],
  en: [
    { year: "1946", title: "Founding of the Greek Union of the Netherlands (EEO)" },
    { year: "1954", title: "Foundations of the church" },
    { year: "1957", title: "Inauguration of the church" },
    { year: "1959", title: "First single-room Greek school" },
    { year: "1961", title: "Building purchase" },
    { year: "1969", title: "Greek school at the EEO" },
    { year: "1992", title: "Festival at Schouwburgplein" },
    { year: "1994", title: "Visit of the Ecumenical Patriarch" },
    { year: "2010", title: "Church transferred to the Metropolis" },
    { year: "2017", title: "Founding of the cultural group The Greek House" },
    { year: "2022", title: "Partial renovation of the Greek House" },
    { year: "2024", title: "Restoration of the building façade" },
    { year: "2026", title: "Celebration of 80 years since the founding of the EEO" },
  ],
};

const items = milestones[lang];
---

<Layout title={t(lang, "history.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "history.title")}</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl">
        {t(lang, "history.intro")}
      </p>

      <div class="mt-12 relative">
        {/* Timeline line */}
        <div class="absolute left-6 top-0 bottom-0 w-1 bg-black sm:left-1/2 sm:-translate-x-0.5"></div>

        <div class="space-y-10">
          {items.map((item, i) => (
            <div class:list={["relative flex items-start gap-6", i % 2 === 0 ? "sm:flex-row" : "sm:flex-row-reverse"]}>
              {/* Dot */}
              <div class="absolute left-6 sm:left-1/2 -translate-x-1/2 z-10">
                <div class="size-5 border-2 border-black bg-accent-gold rotate-45"></div>
              </div>

              {/* Content */}
              <div class:list={["ml-14 sm:ml-0 sm:w-[calc(50%-2rem)]", i % 2 === 0 ? "sm:pr-8 sm:text-right" : "sm:pl-8"]}>
                <BrutCard class="bg-white p-5">
                  <span class="inline-block border-2 border-black bg-primary px-3 py-1 text-sm font-extrabold text-white">
                    {item.year}
                  </span>
                  <h3 class="mt-3 text-lg font-extrabold">{item.title}</h3>
                </BrutCard>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
