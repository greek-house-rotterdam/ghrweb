---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const milestones: Record<Lang, { year: string; title: string; desc: string }[]> = {
  gr: [
    { year: "1944", title: "Ίδρυση του Συλλόγου", desc: "Οι πρώτοι Έλληνες μετανάστες στο Ρότερνταμ ιδρύουν τον σύλλογο ως τόπο συνάντησης και πολιτιστικής διατήρησης." },
    { year: "1960s", title: "Ανάπτυξη της κοινότητας", desc: "Μεγάλο κύμα Ελλήνων μεταναστών φτάνει στην Ολλανδία. Ο σύλλογος γίνεται κέντρο στήριξης και ένταξης." },
    { year: "1980s", title: "Πολιτιστικές δραστηριότητες", desc: "Ξεκινούν τα μαθήματα ελληνικών χορών, γλώσσας και τέχνης. Το Ελληνικό Σπίτι αποκτά σταθερή παρουσία." },
    { year: "2000s", title: "Ανανέωση και εκσυγχρονισμός", desc: "Νέα γενιά μελών αναλαμβάνει τη διοίκηση. Ο σύλλογος επεκτείνει τις δραστηριότητές του σε νεότερα μέλη." },
    { year: "2020s", title: "Ψηφιακή εποχή", desc: "Ο σύλλογος αναπτύσσει ψηφιακή παρουσία, ιστοσελίδα και μέσα κοινωνικής δικτύωσης για να φτάσει σε νεότερες γενιές." },
    { year: "2026", title: "Νέα ιστοσελίδα", desc: "Λανσάρισμα της νέας τρίγλωσσης ιστοσελίδας — ένα νέο κεφάλαιο στην ψηφιακή μας ιστορία." },
  ],
  nl: [
    { year: "1944", title: "Oprichting van de Vereniging", desc: "De eerste Griekse migranten in Rotterdam richten de vereniging op als ontmoetingsplaats en cultureel behoud." },
    { year: "1960s", title: "Groei van de gemeenschap", desc: "Een grote golf Griekse migranten komt naar Nederland. De vereniging wordt een centrum voor steun en integratie." },
    { year: "1980s", title: "Culturele activiteiten", desc: "Lessen in Griekse dans, taal en kunst beginnen. Het Grieks Huis krijgt een vaste plek in Rotterdam." },
    { year: "2000s", title: "Vernieuwing en modernisering", desc: "Een nieuwe generatie leden neemt het bestuur over. De vereniging breidt activiteiten uit naar jongere leden." },
    { year: "2020s", title: "Digitaal tijdperk", desc: "De vereniging ontwikkelt een online aanwezigheid met website en sociale media om jongere generaties te bereiken." },
    { year: "2026", title: "Nieuwe website", desc: "Lancering van de nieuwe drietalige website — een nieuw hoofdstuk in onze digitale geschiedenis." },
  ],
  en: [
    { year: "1944", title: "Founding of the Association", desc: "The first Greek migrants in Rotterdam establish the association as a meeting place and cultural preservation hub." },
    { year: "1960s", title: "Community Growth", desc: "A large wave of Greek migrants arrives in the Netherlands. The association becomes a center for support and integration." },
    { year: "1980s", title: "Cultural Activities", desc: "Greek dance, language, and art classes begin. The Greek House establishes a permanent presence in Rotterdam." },
    { year: "2000s", title: "Renewal and Modernization", desc: "A new generation of members takes over leadership. The association expands activities to younger members." },
    { year: "2020s", title: "Digital Era", desc: "The association develops an online presence with a website and social media to reach younger generations." },
    { year: "2026", title: "New Website", desc: "Launch of the new trilingual website — a new chapter in our digital history." },
  ],
};

const items = milestones[lang];
---

<Layout title={t(lang, "history.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "history.title")}</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl">
        {t(lang, "history.intro")}
      </p>

      <div class="mt-12 relative">
        {/* Timeline line */}
        <div class="absolute left-6 top-0 bottom-0 w-1 bg-black sm:left-1/2 sm:-translate-x-0.5"></div>

        <div class="space-y-10">
          {items.map((item, i) => (
            <div class:list={["relative flex items-start gap-6", i % 2 === 0 ? "sm:flex-row" : "sm:flex-row-reverse"]}>
              {/* Dot */}
              <div class="absolute left-6 sm:left-1/2 -translate-x-1/2 z-10">
                <div class="size-5 border-2 border-black bg-accent-gold rotate-45"></div>
              </div>

              {/* Content */}
              <div class:list={["ml-14 sm:ml-0 sm:w-[calc(50%-2rem)]", i % 2 === 0 ? "sm:pr-8 sm:text-right" : "sm:pl-8"]}>
                <div class="border-2 border-black bg-white p-5 shadow-[4px_4px_0_0_#000]">
                  <span class="inline-block border-2 border-black bg-primary px-3 py-1 text-sm font-extrabold text-white">
                    {item.year}
                  </span>
                  <h3 class="mt-3 text-lg font-extrabold">{item.title}</h3>
                  <p class="mt-2 text-sm text-gray-600">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
