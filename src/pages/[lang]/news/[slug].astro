---
import Layout from "../../../layouts/Layout.astro";
import { t } from "../../../i18n/ui";
import type { Lang } from "../../../i18n/utils";
import { getCollection, render } from "astro:content";
import BrutButton from "../../../components/BrutButton.astro";

export async function getStaticPaths() {
  const allNews = await getCollection("news");
  return allNews.map((post) => {
    const lang = post.id.split("/")[0];
    const slug = post.id.split("/").slice(1).join("/");
    return { params: { lang, slug }, props: { post } };
  });
}

const { post } = Astro.props;
const { lang } = Astro.params as { lang: Lang };
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description} lang={lang}>
  <article class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <BrutButton href={`/${lang}/news`} size="sm" class="bg-white text-black hover:bg-accent-gold">
        ← {t(lang, "common.back")}
      </BrutButton>

      <div class="mt-8">
        <div class="flex flex-wrap gap-2">
          <span class="inline-block border border-black bg-accent-gold px-2 py-0.5 text-xs font-bold uppercase">
            {post.data.date.toLocaleDateString(lang)}
          </span>
          {post.data.translation_locked && (
            <span class="inline-block border border-black bg-blue-100 px-2 py-0.5 text-xs font-bold uppercase">
              {t(lang, "common.manually-edited")}
            </span>
          )}
        </div>
        <h1 class="mt-3 text-3xl font-extrabold text-black sm:text-4xl">{post.data.title}</h1>
        <p class="mt-3 text-lg text-gray-600">{post.data.description}</p>
      </div>

      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.title}
          class="mt-8 w-full border-2 border-black object-cover"
        />
      )}

      <div class="mt-10 border-t-2 border-black pt-8 prose prose-lg max-w-none prose-headings:font-extrabold prose-a:text-primary prose-a:underline prose-a:decoration-2">
        <Content />
      </div>
    </div>
  </article>
</Layout>
