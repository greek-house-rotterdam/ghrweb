---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";
import { getStaticLangPaths, type Lang } from "../../i18n/utils";
import { getCollection } from "astro:content";

export const getStaticPaths = getStaticLangPaths;

const { lang } = Astro.params as { lang: Lang };

const allActivities = await getCollection("activities");
const activities = allActivities
  .filter((a) => a.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={t(lang, "activities.title")} lang={lang}>
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4">
      <h1 class="text-4xl font-extrabold text-black">{t(lang, "activities.title")}</h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl">
        {t(lang, "activities.intro")}
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {activities.map((activity) => (
          <a
            href={`/${lang}/activities/${activity.id.split("/").pop()}`}
            class="block border-2 border-black p-6 bg-white shadow-[4px_4px_0_0_#000] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all"
          >
            {activity.data.emoji && (
              <span class="text-4xl">{activity.data.emoji}</span>
            )}
            <h3 class="mt-4 text-xl font-extrabold">{activity.data.title}</h3>
            <p class="mt-2 text-sm text-gray-700">{activity.data.description}</p>
            {activity.data.schedule && (
              <p class="mt-3 text-xs font-bold text-primary">
                {activity.data.schedule}
              </p>
            )}
          </a>
        ))}
      </div>

      {activities.length === 0 && (
        <div class="mt-10 border-2 border-black border-dashed bg-gray-50 p-10 text-center">
          <p class="text-gray-500 font-bold">{t(lang, "activities.none")}</p>
        </div>
      )}
    </div>
  </section>
</Layout>
