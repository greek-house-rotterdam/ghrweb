---
/**
 * Brutalist button/link. Thick border, offset shadow, press-down hover effect.
 * Renders as <a> when `href` is provided, <button> otherwise.
 * Use `size="sm"` for secondary/back buttons (3px shadow, smaller padding).
 */
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a"> & HTMLAttributes<"button"> & {
  href?: string;
  size?: "sm" | "md";
};

const { href, size = "md", class: className, ...rest } = Astro.props;
const Tag = href ? "a" : "button";
const classes = [
  "inline-block border-2 border-black font-bold transition-all",
  size === "sm"
    ? "px-4 py-2 text-sm shadow-[3px_3px_0_0_#000] hover:shadow-none"
    : "px-8 py-4 font-extrabold shadow-[4px_4px_0_0_#000] hover:shadow-none hover:translate-x-1 hover:translate-y-1",
  className,
];
---

<Tag href={href} class:list={classes} {...rest}>
  <slot />
</Tag>
