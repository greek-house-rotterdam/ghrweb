---
import { t } from "../i18n/ui";
import LanguagePicker from "./LanguagePicker.astro";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const navItems = [
  { href: `/${lang}`, label: t(lang, "nav.home") },
  { href: `/${lang}/history`, label: t(lang, "nav.history") },
  { href: `/${lang}/teams`, label: t(lang, "nav.teams") },
  { href: `/${lang}/news`, label: t(lang, "nav.news") },
  { href: `/${lang}/events`, label: t(lang, "nav.events") },
  { href: `/${lang}/about`, label: t(lang, "nav.about") },
  { href: `/${lang}/faq`, label: t(lang, "nav.faq") },
  { href: `/${lang}/contact`, label: t(lang, "nav.contact") },
] as const;
---

<header class="sticky top-0 z-50 border-b-4 border-black bg-white/95 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href={`/${lang}`} class="text-2xl font-extrabold tracking-tight">
      GHR<span class="text-blue-700">.</span>
    </a>

    <div class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2 text-sm font-bold uppercase tracking-wide text-black hover:bg-yellow-300 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <LanguagePicker lang={lang} />
      <a
        href={`/${lang}/become-a-member`}
        class="hidden sm:inline-block border-2 border-black bg-blue-700 px-4 py-2 text-sm font-bold text-white shadow-[4px_4px_0_0_#000] hover:bg-blue-800 hover:shadow-none transition-all"
      >
        {t(lang, "nav.become-a-member")}
      </a>

      {/* Mobile menu toggle */}
      <details class="lg:hidden group relative">
        <summary class="flex cursor-pointer items-center border-2 border-black p-2 shadow-[3px_3px_0_0_#000] hover:bg-yellow-300 hover:shadow-none transition-all list-none [&::-webkit-details-marker]:hidden">
          <svg class="size-6 group-open:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="size-6 hidden group-open:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </summary>

        <div class="absolute right-0 top-full mt-2 w-64 border-2 border-black bg-white shadow-[4px_4px_0_0_#000] z-50">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="block px-4 py-3 text-sm font-bold uppercase tracking-wide text-black hover:bg-yellow-300 border-b border-black last:border-b-0"
            >
              {item.label}
            </a>
          ))}
          <a
            href={`/${lang}/become-a-member`}
            class="block px-4 py-3 text-sm font-bold uppercase tracking-wide text-white bg-blue-700 hover:bg-blue-800 sm:hidden"
          >
            {t(lang, "nav.become-a-member")}
          </a>
        </div>
      </details>
    </div>
  </nav>
</header>
