---
import { t } from "../i18n/ui";
import LanguagePicker from "./LanguagePicker.astro";
import type { Lang } from "../i18n/utils";
import { Sheet, SheetTrigger, SheetContent, SheetHeader, SheetTitle } from "@/components/starwind/sheet";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const navItems = [
  { href: `/${lang}`, label: t(lang, "nav.home") },
  { href: `/${lang}/events`, label: t(lang, "nav.events") },
  { href: `/${lang}/teams`, label: t(lang, "nav.activities") },
  { href: `/${lang}/news`, label: t(lang, "nav.news") },
  { href: `/${lang}/about`, label: t(lang, "nav.about") },
  { href: `/${lang}/resources`, label: t(lang, "nav.resources") },
  { href: `/${lang}/contact`, label: t(lang, "nav.contact") },
] as const;
---

<header class="sticky top-0 z-50 border-b-4 border-black bg-white/95 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href={`/${lang}`} class="text-2xl font-extrabold tracking-tight">
      GHR<span class="text-primary">.</span>
    </a>

    <div class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2 text-sm font-bold uppercase tracking-wide text-black hover:bg-accent-gold transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <LanguagePicker lang={lang} />
      <a
        href={`/${lang}/become-a-member`}
        class="hidden sm:inline-block border-2 border-black bg-primary px-4 py-2 text-sm font-bold text-white shadow-[4px_4px_0_0_#000] hover:bg-primary-dark hover:shadow-none transition-all"
      >
        {t(lang, "nav.become-a-member")}
      </a>

      {/* Mobile menu — Starwind Sheet */}
      <Sheet class="lg:hidden">
        <SheetTrigger class="border-2 border-black p-2 shadow-[3px_3px_0_0_#000] hover:bg-accent-gold hover:shadow-none transition-all">
          <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </SheetTrigger>
        <SheetContent side="right">
          <SheetHeader>
            <SheetTitle>
              <span class="text-2xl font-extrabold tracking-tight">
                GHR<span class="text-primary">.</span>
              </span>
            </SheetTitle>
          </SheetHeader>
          <nav class="mt-4 flex flex-col">
            {navItems.map((item) => (
              <a
                href={item.href}
                class="px-4 py-3 text-sm font-bold uppercase tracking-wide text-black hover:bg-accent-gold border-b border-black last:border-b-0"
              >
                {item.label}
              </a>
            ))}
            <a
              href={`/${lang}/become-a-member`}
              class="mt-4 mx-4 border-2 border-black bg-primary px-4 py-3 text-center text-sm font-bold uppercase tracking-wide text-white hover:bg-primary-dark transition-all"
            >
              {t(lang, "nav.become-a-member")}
            </a>
          </nav>
        </SheetContent>
      </Sheet>
    </div>
  </nav>
</header>
