---
import { LANGUAGES, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="flex items-center">
  {Object.entries(LANGUAGES).map(([code, _label]) => {
    const targetPath = currentPath.replace(`/${lang}`, `/${code}`);
    const isActive = code === lang;
    return (
      <a
        href={targetPath}
        class:list={[
          "px-2 py-1 text-xs font-bold uppercase border-2 border-black -ml-0.5 first:ml-0 transition-all",
          isActive
            ? "bg-black text-white"
            : "bg-white text-black hover:bg-accent",
        ]}
        aria-current={isActive ? "page" : undefined}
      >
        {code.toUpperCase()}
      </a>
    );
  })}
</div>
